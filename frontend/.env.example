# ─── Frontend environment variables ───
# Copy this file to ".env" and adjust as needed. Never commit ".env".

# Base URL of the backend API.
# Leave EMPTY for production when the API and frontend are served from the
# same origin (the app will call "/api" relatively).
# For local development with the Vite dev-server proxy, "/api" also works.
VITE_API_URL=/api
