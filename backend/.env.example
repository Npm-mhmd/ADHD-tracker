# ─── Backend environment variables ───
# Copy this file to ".env" and fill in real values. Never commit ".env".

# Node environment: "development" or "production"
NODE_ENV=development

# Port the API server listens on
PORT=5000

# MongoDB connection string (required in production)
MONGODB_URI=mongodb://127.0.0.1:27017/adhd-monitoring

# Secret used to sign JWTs (REQUIRED, min 16 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# How long issued tokens stay valid (e.g. 7d, 24h, 30m)
JWT_EXPIRES_IN=7d

# Secret used to encrypt student names at rest (REQUIRED, min 16 chars)
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ENCRYPTION_KEY=

# Comma-separated list of allowed browser origins for CORS.
# In production this MUST be set to your deployed frontend origin(s).
# Leave empty in production if frontend is served from the same origin.
CLIENT_ORIGIN=http://localhost:3000,http://localhost:5173
